# Copy to .env and adjust.

# Host directory bind-mounted into the router container as STACK_DATA_ROOT.
# Will hold backends.json, seeds/, users/, router.db.
HOST_STACK_ROOT=./data
STACK_DATA_ROOT=/data

# Router (loopback only by default; frontend reverse-proxies to it)
ROUTER_BIND_HOST=127.0.0.1
ROUTER_PORT=18080
JWT_SECRET=CHANGE_ME_TO_RANDOM_HEX
COOKIE_SECURE=false

ALLOW_SIGNUP=true
INVITE_CODE=

BOOTSTRAP_ADMIN_EMAIL=admin@local
BOOTSTRAP_ADMIN_PASSWORD=changeme
BOOTSTRAP_ADMIN_NAME=Admin

DEFAULT_IDLE_SECONDS=600
REAPER_INTERVAL_SECONDS=30

BACKEND_PORT_START=19000
BACKEND_PORT_END=19999
BACKEND_STARTUP_TIMEOUT=90

# Frontend
FRONTEND_BIND_HOST=0.0.0.0
FRONTEND_PORT=18000

# --- Upstream LLM (OpenAI-compatible) -----------------------------------
# NOTE: We deliberately do NOT keep upstream LLM credentials in this file
# any more. The router never reads LLM_BASE_URL / LLM_API_KEY / LLM_MODEL
# from process env. Instead, the admin sets all three once in the web UI
# (Settings → Backend API keys → Global) and toggles "share with users" on
# the same card. Other users either inherit that value or provide their
# own. See docs/per-user-env-overrides.md.
#
# Tip: if you spawn runners that need to reach an OpenAI-compatible proxy
# running as a sidecar container on the same host, add that docker network
# to the backend in backends.json:
#   "extra_networks": ["amd-bridge-standalone_default"]
# and set Base URL to e.g. http://amd-bridge-proxy:8080/v1 in the admin UI.
