{
  "providers": {
    "custom": {
      "apiKey": "${LLM_API_KEY}",
      "apiBase": "${LLM_BASE_URL}"
    }
  },
  "agents": {
    "defaults": {
      "provider": "custom",
      "model": "${LLM_MODEL}",
      "maxTokens": 8192,
      "temperature": 0.2,
      "timezone": "Asia/Shanghai",
      "idleCompactAfterMinutes": 15
    }
  },
  "tools": {
    "restrictToWorkspace": true,
    "exec": {
      "sandbox": "bwrap"
    },
    "web": {
      "enable": true,
      "search": {
        "provider": "duckduckgo"
      }
    }
  },
  "channels": {},
  "api": {
    "host": "0.0.0.0",
    "port": 8900
  }
}